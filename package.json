{
  "name": "@aeswibon/pipeline-compose",
  "version": "0.1.0",
  "private": false,
  "type": "module",
  "description": "Compile declarative pipeline YAML into ordered GitHub Actions reusable-workflow graphs",
  "scripts": {
    "build": "tsc && pnpm run bundle",
    "bundle": "pnpm run bundle:compile && pnpm run bundle:eval",
    "bundle:compile": "ncc build src/compile/index.ts -o compile/dist -s",
    "bundle:eval": "ncc build src/eval/index.ts -o eval/dist -s",
    "test": "vitest run",
    "test:watch": "vitest",
    "compile": "tsx bin/pipeline-compose.ts compile",
    "act:ci": "bash scripts/act-test.sh ci",
    "act:compile": "bash scripts/act-test.sh compile"
  },
  "packageManager": "pnpm@10.12.1",
  "dependencies": {
    "@actions/core": "^1.11.1",
    "ajv": "^8.17.1",
    "yaml": "^2.8.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "@vercel/ncc": "^0.38.3",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  },
  "bin": {
    "pipeline-compose": "./bin/pipeline-compose.ts"
  }
}
