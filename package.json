{
  "name": "pipeline-compose",
  "version": "1.10.0",
  "private": true,
  "description": "Cross-Repo Orchestrator for GitHub Actions — define workflow execution order via pipeline YAML",
  "packageManager": "pnpm@10.12.1",
  "scripts": {
    "build": "pnpm -r run build",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "bundle:actions": "pnpm --filter '@aeswibon/pipeline-compose-action-run' --filter '@aeswibon/pipeline-compose-action-compile' --filter '@aeswibon/pipeline-compose-action-eval' --filter '@aeswibon/pipeline-compose-action-export' --filter '@aeswibon/pipeline-compose-action-context-merge' run bundle",
    "compile": "pnpm exec tsx packages/cli/src/main.ts compile",
    "eval": "pnpm exec tsx packages/cli/src/main.ts eval",
    "validate": "pnpm exec tsx packages/cli/src/main.ts validate",
    "init": "pnpm exec tsx packages/cli/src/main.ts init",
    "sync:workflows": "pnpm exec tsx packages/cli/src/main.ts sync",
    "act:ci": "bash scripts/act-test.sh ci",
    "act:compile": "bash scripts/act-test.sh compile",
    "act:full": "bash scripts/act-test.sh full",
    "lint:workflows": "bash scripts/lint-workflows.sh",
    "publish:actions": "pnpm run bundle:actions && bash scripts/publish-action-packages.sh"
  },
  "devDependencies": {
    "@types/node": "^25.9.3",
    "@vitest/coverage-v8": "^4.1.8",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "vitest": "^4.1.8"
  },
  "pnpm": {
    "overrides": {
      "esbuild": ">=0.28.1"
    }
  }
}
